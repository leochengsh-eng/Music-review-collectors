<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Album Review Weekly Digest</title><style>body{margin:0;background:#f6f3ef;color:#241f1b;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}.wrap{max-width:920px;margin:auto;padding:28px 16px}h1{font-size:30px;margin:0}.sub{color:#756b62}.section{margin-top:28px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px}.card{background:#fff;border:1px solid #e8ded3;border-radius:18px;padding:16px;box-shadow:0 6px 18px #0000000a}.score{float:right;background:#151515;color:white;border-radius:999px;padding:6px 10px;font-weight:700}.tag{display:inline-block;background:#efe7dc;border-radius:999px;padding:3px 8px;margin:2px;font-size:12px}a{color:#8d3b22}.meta{font-size:13px;color:#6b625b}.cn{line-height:1.55}.empty{color:#8b8178;font-style:italic}@media(max-width:600px){.wrap{padding:20px 12px}.score{float:none;display:inline-block;margin-bottom:8px}}</style></head><body><div class="wrap"><h1>Album Review Weekly Digest</h1><div class="sub">{{ window.start }} to {{ window.end }} · UTC+8 weekly cycle</div><div class="section"><h2>1. Highlights</h2><p class="meta">Recommended: {{ recommended|length }} · New Reviews: {{ new|length }} · Aggregator Finds: {{ aggregators|length }} · Manual Check: {{ manual|length }}</p></div><div class="section"><h2>2. Recommended Albums by Genre</h2>{% for genre, albums in by_genre.items() %}<h3>{{ genre }}</h3>{% if albums %}<div class="grid">{% for item in albums %}{% include 'weekly_digest_card.html.j2' %}{% endfor %}</div>{% else %}<p class="empty">No items.</p>{% endif %}{% endfor %}</div><div class="section"><h2>3. New Reviews Detected</h2><div class="grid">{% for item in new %}{% include 'weekly_digest_card.html.j2' %}{% else %}<p class="empty">No new reviews detected.</p>{% endfor %}</div></div><div class="section"><h2>4. High-Score Aggregator Finds</h2><div class="grid">{% for item in aggregators %}{% include 'weekly_digest_card.html.j2' %}{% else %}<p class="empty">No aggregator finds.</p>{% endfor %}</div></div><div class="section"><h2>5. Late Additions</h2><div class="grid">{% for item in late %}{% include 'weekly_digest_card.html.j2' %}{% else %}<p class="empty">No late additions.</p>{% endfor %}</div></div><div class="section"><h2>6. Manual Check</h2><div class="grid">{% for item in manual %}{% include 'weekly_digest_card.html.j2' %}{% else %}<p class="empty">No manual checks.</p>{% endfor %}</div></div></div></body></html>
