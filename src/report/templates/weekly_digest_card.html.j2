<div class="card"><span class="score">{{ item.normalized_score_10 if item.normalized_score_10 is not none else '—' }}/10</span><h3>{{ item.artist }} — <em>{{ item.album }}</em></h3><div class="meta">{{ item.release_type }} · {{ item.genre_bucket }}{% if item.subgenre %} / {{ item.subgenre }}{% endif %} · {{ item.review_date or 'date unknown' }}</div><p>{% if item.raw_score %}<span class="tag">{{ item.review_source }} {{ item.raw_score }}</span>{% else %}<span class="tag">{{ item.review_source }} no score</span>{% endif %}<span class="tag">{{ item.status }}</span></p><p class="cn">{{ item.brief_review_cn }}</p>{% if item.recommended_track %}<p class="meta">Recommended track: {{ item.recommended_track }}</p>{% endif %}{% if item.manual_check_reason %}<p class="meta">Manual check: {{ item.manual_check_reason }}</p>{% endif %}{% if item.review_url %}<p><a href="{{ item.review_url }}">Read Review</a></p>{% endif %}</div>
